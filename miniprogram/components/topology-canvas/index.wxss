.topology-canvas-container {
  width: 100%;
  height: 100%;
  position: relative;
}

.topology-canvas {
  width: 100%;
  height: 100%;
  background-color: #f5f5f5;
}

.popup-content {
  padding: 20rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-align: center;
}

.popup-item {
  padding: 15rpx 0;
  border-bottom: 1rpx solid #eee;
}

.popup-item:last-child {
  border-bottom: none;
}

.popup-item .label {
  font-weight: bold;
  color: #666;
}
