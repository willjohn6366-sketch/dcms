.circuit-detail-container {
  padding-bottom: 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.topology-section {
  margin-top: 20rpx;
  background-color: #fff;
  padding: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.topology-wrapper {
  width: 100%;
  height: 500rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  overflow: hidden;
}

.topology-hint {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}
